# -----------------------------------------------------------------------
# Archie — required environment variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env — it is gitignored.
# -----------------------------------------------------------------------

# Discord bot token — from discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=

# Discord server (guild) ID — right-click your server name → Copy Server ID
# (requires Developer Mode: Settings → Advanced → Developer Mode)
DISCORD_GUILD_ID=

# Discord channel ID — right-click the private accountability channel → Copy Channel ID
DISCORD_CHANNEL_ID=

# Your Discord user ID — right-click your own username → Copy User ID
# This grants you owner-level commands (/new, /model, etc.) via DM
DISCORD_OWNER_ID=

# OpenAI API key — platform.openai.com/api-keys (used for gpt-5 primary model)
OPENAI_API_KEY=

# Anthropic API key — console.anthropic.com/settings/keys (used as claude-sonnet-4-6 fallback)
ANTHROPIC_API_KEY=

# OpenClaw gateway token — generate with: openssl rand -hex 24
# Used to authenticate CLI/device connections to the local gateway
OPENCLAW_GATEWAY_TOKEN=

# Notion integration token — notion.so/my-integrations → New integration → Internal Integration Secret
# Leave blank to start without Notion (Archie will warn on startup)
NOTION_TOKEN=

{
  "agents": {
    "defaults": {
      "workspace": "/app/workspace",
      "models": {
        "openai/gpt-5":   { "agentRuntime": { "id": "pi" } },
        "openai/gpt-5.4": { "agentRuntime": { "id": "pi" } }
      },
      "model": {
        "primary":   "openai/gpt-5",
        "fallbacks": ["openai/gpt-5.4"]
      },
      "thinkingDefault":       "low",
      "blockStreamingDefault": "off",
      "params": {
        "cacheRetention": "long"
      }
    }
  },

  "models": {
    "providers": {
      "openai": {
        "models": [
          { "id": "gpt-5",   "name": "gpt-5" },
          { "id": "gpt-5.4", "name": "gpt-5.4" }
        ]
      }
    }
  },

  "gateway": {
    "mode": "local",
    "auth": {
      "mode":  "token",
      "token": "REDACTED_GATEWAY_TOKEN",
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs":    60000,
        "lockoutMs":   300000
      }
    },
    "port": 18789,
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": ["http://localhost:18789", "http://127.0.0.1:18789"]
    }
  },

  "session": {
    "dmScope": "per-channel-peer"
  },

  "plugins": {
    "entries": {
      "openai":        { "enabled": true },
      "discord":       { "enabled": true },
      "browser":       { "enabled": false },
      "talk-voice":    { "enabled": false },
      "device-pair":   { "enabled": false },
      "phone-control": { "enabled": false }
    }
  },

  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode":     "api_key"
      }
    }
  },

  "channels": {
    "discord": {
      "enabled":     true,
      "token":       "REDACTED_DISCORD_BOT_TOKEN",
      "groupPolicy": "open",
      "dmPolicy":    "allowlist",
      "allowFrom":   "REDACTED_DISCORD_ALLOWLIST",
      "guilds": {
        "REDACTED_DISCORD_GUILD_ID": {
          "requireMention": false,
          "channels": {
            "REDACTED_DISCORD_CHANNEL_ID": {}
          }
        }
      }
    },
    "telegram": {
      "enabled": false
    }
  },

  "commands": {
    "ownerAllowFrom": [
      "discord:REDACTED_DISCORD_OWNER_ID"
    ]
  },

  "messages": {
    "groupChat": {
      "visibleReplies": "message_tool"
    }
  },

  "mcp": {
    "servers": {
      "notion": {
        "command": "notion-mcp-server",
        "env": {
          "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer REDACTED_NOTION_TOKEN\", \"Notion-Version\": \"2022-06-28\"}"
        }
      }
    }
  }
}

{
  "_note": "Archie's OpenClaw config. Secrets are injected at container startup by entrypoint.sh — REDACTED_* values are never real credentials.",

  "agents": {
    "defaults": {
      "workspace": "/app/workspace",
      "models": {
        "openai/gpt-5":                { "agentRuntime": { "id": "pi" } },
        "openai/gpt-5.4":              { "agentRuntime": { "id": "pi" } },
        "anthropic/claude-sonnet-4-6": { "params": { "thinking": "low" } },
        "anthropic/claude-haiku-4-5":  {}
      },
      "model": {
        "primary":   "openai/gpt-5",
        "fallbacks": ["anthropic/claude-sonnet-4-6"]
      },
      "thinkingDefault":       "medium",
      "blockStreamingDefault": "off",
      "params": {
        "cacheRetention": "long"
      }
    }
  },

  "gateway": {
    "mode": "local",
    "auth": {
      "mode":  "token",
      "token": "REDACTED_GATEWAY_TOKEN",
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs":    60000,
        "lockoutMs":   300000
      }
    },
    "port": 18789,
    "bind": "lan"
  },

  "session": {
    "dmScope": "per-channel-peer"
  },

  "plugins": {
    "entries": {
      "openai":    { "enabled": true },
      "anthropic": { "enabled": true },
      "discord":   { "enabled": true }
    }
  },

  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode":     "api_key"
      },
      "anthropic:default": {
        "provider": "anthropic",
        "mode":     "api_key"
      }
    }
  },

  "channels": {
    "discord": {
      "enabled":     true,
      "token":       "REDACTED_DISCORD_BOT_TOKEN",
      "groupPolicy": "open",
      "guilds": {
        "REDACTED_DISCORD_GUILD_ID": {
          "channels": {
            "REDACTED_DISCORD_CHANNEL_ID": {}
          }
        }
      }
    },
    "telegram": {
      "enabled": false
    }
  },

  "commands": {
    "ownerAllowFrom": [
      "discord:REDACTED_DISCORD_OWNER_ID"
    ]
  },

  "messages": {
    "groupChat": {
      "visibleReplies": "message_tool"
    }
  },

  "mcp": {
    "servers": {
      "notion": {
        "command": "notion-mcp-server",
        "env": {
          "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer REDACTED_NOTION_TOKEN\", \"Notion-Version\": \"2022-06-28\"}"
        }
      }
    }
  }
}

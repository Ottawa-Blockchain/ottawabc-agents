{
  "agents": {
    "defaults": {
      "workspace": "/home/nolan/ottawabc-bot/workspace",
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "anthropic/claude-haiku-4-5"
        ]
      },
      "typingMode": "thinking"
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "REDACTED_GATEWAY_TOKEN"
    },
    "port": 18789,
    "bind": "loopback"
  },
  "channels": {
    "discord": {
      "enabled": true
    }
  },
  "plugins": {
    "entries": {
      "anthropic": {
        "enabled": true
      }
    }
  },
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    }
  },
  "_note": "Sanitized config — replace GATEWAY_TOKEN with actual value from .env on restore. Copy to ~/.openclaw/openclaw.json on the VPS."
}

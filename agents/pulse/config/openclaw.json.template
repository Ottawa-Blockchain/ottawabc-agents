{
  "agents": {
    "defaults": {
      "workspace": "/app/workspace",
      "model": {
        "primary": "openai/gpt-5",
        "fallbacks": [
          "openai/gpt-4o"
        ]
      },
      "typingMode": "thinking"
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "port": 18790,
    "bind": "loopback"
  },
  "channels": {
    "discord": {
      "enabled": true
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": true
      }
    }
  },
  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  }
}
